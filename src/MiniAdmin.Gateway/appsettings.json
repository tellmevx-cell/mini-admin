{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitLimit": 1200,
    "WindowSeconds": 60,
    "QueueLimit": 0,
    "LoginPermitLimit": 20,
    "LoginWindowSeconds": 60,
    "LoginQueueLimit": 0
  },
  "Canary": {
    "Enabled": false,
    "Percentage": 0,
    "ReleaseHeaderName": "X-Release-Channel",
    "CanaryHeaderValue": "canary",
    "StableHeaderValue": "stable",
    "TenantWhitelist": [],
    "UserWhitelist": [],
    "IpWhitelist": [],
    "HeaderMatches": {}
  },
  "CircuitBreaker": {
    "Enabled": false,
    "FailureThreshold": 5,
    "BreakDurationSeconds": 30
  },
  "ReverseProxy": {
    "Routes": {
      "miniadmin-api": {
        "ClusterId": "miniadmin_api",
        "Match": {
          "Path": "/api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api"
          }
        ]
      },
      "miniadmin-oidc-discovery": {
        "ClusterId": "miniadmin_api",
        "Match": {
          "Path": "/.well-known/{**catch-all}"
        }
      },
      "miniadmin-oidc-connect": {
        "ClusterId": "miniadmin_api",
        "Match": {
          "Path": "/connect/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "miniadmin_api": {
        "LoadBalancingPolicy": "MiniAdminCanary",
        "Destinations": {
          "stable": {
            "Address": "http://localhost:5021/",
            "Metadata": {
              "Release": "stable"
            }
          },
          "canary": {
            "Address": "http://localhost:5021/",
            "Metadata": {
              "Release": "canary"
            }
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
