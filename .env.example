# Copy this file to .env before running docker compose.
# Replace every value ending in _change_me before exposing the stack outside your machine.

# API and gateway are bound to loopback by default. Expose only the web port publicly.
MINIADMIN_HTTP_PORT=127.0.0.1:8080
MINIADMIN_GATEWAY_PORT=127.0.0.1:8088
MINIADMIN_WEB_PORT=5666

# Optional image overrides for private registries or domestic mirrors.
MINIADMIN_MYSQL_IMAGE=mysql:8.4
MINIADMIN_REDIS_IMAGE=redis:7.4-alpine
MINIADMIN_DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0
MINIADMIN_DOTNET_ASPNET_IMAGE=mcr.microsoft.com/dotnet/aspnet:10.0
MINIADMIN_NODE_IMAGE=node:24-alpine
MINIADMIN_NGINX_IMAGE=nginx:1.27-alpine

MINIADMIN_GATEWAY_RATE_LIMITING_ENABLED=true
MINIADMIN_GATEWAY_RATE_LIMITING_PERMIT_LIMIT=1200
MINIADMIN_GATEWAY_RATE_LIMITING_WINDOW_SECONDS=60
MINIADMIN_GATEWAY_LOGIN_RATE_LIMITING_PERMIT_LIMIT=20
MINIADMIN_GATEWAY_LOGIN_RATE_LIMITING_WINDOW_SECONDS=60
MINIADMIN_GATEWAY_CANARY_ENABLED=false
MINIADMIN_GATEWAY_CANARY_PERCENTAGE=0
MINIADMIN_CANARY_API_ADDRESS=http://api:8080/
MINIADMIN_GATEWAY_CIRCUIT_BREAKER_ENABLED=true
MINIADMIN_GATEWAY_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
MINIADMIN_GATEWAY_CIRCUIT_BREAKER_BREAK_SECONDS=30

MINIADMIN_NPM_REGISTRY=https://registry.npmmirror.com
MINIADMIN_PNPM_FETCH_TIMEOUT=900000
MINIADMIN_PNPM_FETCH_RETRIES=8
MINIADMIN_PNPM_NETWORK_CONCURRENCY=2

MINIADMIN_JWT_SIGNING_KEY=replace_with_a_long_random_signing_key_change_me
MINIADMIN_OPEN_PLATFORM_SIGNING_KEY=replace_with_a_separate_open_platform_signing_key_change_me
MINIADMIN_OPEN_PLATFORM_ENCRYPTION_KEY=replace_with_a_separate_open_platform_encryption_key_change_me
MINIADMIN_OPENAPI_CREDENTIAL_ENCRYPTION_KEY=replace_with_a_stable_credential_encryption_key_change_me

# Public Web origin and OIDC issuer exposed to third-party clients.
# Change both to your HTTPS domain when using a reverse proxy, keeping the trailing slash.
MINIADMIN_PUBLIC_ORIGIN=http://localhost:5666/
MINIADMIN_OPEN_PLATFORM_ISSUER=http://localhost:5666/
# Development/private-network only. Keep false when the public origin uses HTTPS.
MINIADMIN_OPEN_PLATFORM_ALLOW_INSECURE_HTTP=true

MINIADMIN_MYSQL_DATABASE=mini_admin
MINIADMIN_MYSQL_USER=miniadmin
MINIADMIN_MYSQL_PASSWORD=replace_mysql_password_change_me
MINIADMIN_MYSQL_ROOT_PASSWORD=replace_mysql_root_password_change_me

MINIADMIN_REDIS_PASSWORD=replace_redis_password_change_me

# Maximum time an API instance waits for another instance to finish migrations/seeding.
MINIADMIN_DB_INIT_LOCK_TIMEOUT_SECONDS=180

MINIADMIN_UPLOADS_VOLUME=miniadmin_uploads
MINIADMIN_MYSQL_VOLUME=miniadmin_mysql
MINIADMIN_REDIS_VOLUME=miniadmin_redis
