# Copy this file to .env before running docker compose.
# Replace every value ending in _change_me before exposing the stack outside your machine.

MINIADMIN_HTTP_PORT=8080
MINIADMIN_WEB_PORT=5666

MINIADMIN_NPM_REGISTRY=https://registry.npmmirror.com
MINIADMIN_PNPM_FETCH_TIMEOUT=600000
MINIADMIN_PNPM_FETCH_RETRIES=5
MINIADMIN_PNPM_NETWORK_CONCURRENCY=4

MINIADMIN_JWT_SIGNING_KEY=replace_with_a_long_random_signing_key_change_me

MINIADMIN_MYSQL_DATABASE=mini_admin
MINIADMIN_MYSQL_USER=miniadmin
MINIADMIN_MYSQL_PASSWORD=replace_mysql_password_change_me
MINIADMIN_MYSQL_ROOT_PASSWORD=replace_mysql_root_password_change_me

MINIADMIN_REDIS_PASSWORD=replace_redis_password_change_me

MINIADMIN_UPLOADS_VOLUME=miniadmin_uploads
MINIADMIN_MYSQL_VOLUME=miniadmin_mysql
MINIADMIN_REDIS_VOLUME=miniadmin_redis
